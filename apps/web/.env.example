# Copy to .env.local for local dev. Vercel project vars override these in deployments.

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database (Neon Postgres) — fill in once Phase 1 lands.
# DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"
# DIRECT_URL="postgresql://user:pass@host/dbname?sslmode=require"  # for migrations only

# Clerk auth (https://dashboard.clerk.com/ → API Keys)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# CLERK_SECRET_KEY=""
# CLERK_WEBHOOK_SECRET=""
# Where Clerk redirects after sign in/up; safe to leave at defaults.
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# Stripe (Phase 6)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PRICE_ID_MONTHLY=""
# STRIPE_PRICE_ID_YEARLY=""

# Email (Resend)
# RESEND_API_KEY=""

# Media (Pexels + Cloudflare R2 + Azure Speech)
# PEXELS_API_KEY=""
# AZURE_SPEECH_KEY=""
# AZURE_SPEECH_REGION="eastus"
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="habla-juega"
# R2_PUBLIC_URL="https://media.hablajuega.com"

# Rate limit (Upstash)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Cron auth — Vercel Cron sends this in Authorization header.
# CRON_SECRET=""

# Observability — kept OFF the player route per §8.
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_KEY=""
