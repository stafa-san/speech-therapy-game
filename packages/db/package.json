{
  "name": "@habla/db",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma client + schema for the Habla Juega database (Neon Postgres).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./seed/data": "./src/seed/data/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "seed": "tsx src/seed/index.ts",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "clean": "rm -rf .turbo dist node_modules/.prisma"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx src/seed/index.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@prisma/adapter-neon": "^6.1.0",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@habla/config": "workspace:*",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
