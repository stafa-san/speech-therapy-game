{
  "name": "@habla/config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared ESLint, TypeScript, and Tailwind configuration for the Habla Juega monorepo.",
  "type": "module",
  "files": [
    "eslint",
    "tsconfig",
    "tailwind"
  ],
  "exports": {
    "./eslint/base": "./eslint/base.mjs",
    "./eslint/next": "./eslint/next.mjs",
    "./eslint/library": "./eslint/library.mjs",
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/nextjs.json": "./tsconfig/nextjs.json",
    "./tsconfig/library.json": "./tsconfig/library.json",
    "./tailwind/preset.css": "./tailwind/preset.css"
  },
  "scripts": {
    "lint": "echo 'config-only package; nothing to lint' && exit 0",
    "typecheck": "echo 'config-only package; nothing to typecheck' && exit 0",
    "test": "echo 'config-only package; no tests' && exit 0"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "typescript": ">=5",
    "tailwindcss": ">=4"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "@eslint/js": "^9.17.0",
    "eslint-config-next": "16.2.4",
    "globals": "^15.14.0",
    "typescript-eslint": "^8.18.2"
  }
}
