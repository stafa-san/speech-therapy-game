{
  "name": "@habla/rive",
  "version": "0.0.0",
  "private": true,
  "description": "Rive wrappers + Framer-Motion fallbacks. Lazy-loaded to keep WASM out of the player route's first bundle.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./mascot": "./src/mascot/index.tsx",
    "./reward": "./src/reward/index.tsx"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@rive-app/react-canvas": "^4.18.4",
    "framer-motion": "^11.15.0"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@habla/config": "workspace:*",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^10.3.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "typescript": "^6.0.3"
  }
}
